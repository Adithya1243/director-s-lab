# Director's Lab — Environment Variables
# Copy this file to .env and fill in your values

# ── Gemini AI ──────────────────────────────────────────────────────────────
# Gemini API key from AI Studio (https://aistudio.google.com/apikey)
# Used for Gemini 2.5 Flash (scene generation, clarification, revision preview)
# If left blank, falls back to Vertex AI ADC (uses GOOGLE_CLOUD_PROJECT below)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model ID — update when newer preview IDs are released
GEMINI_MODEL=gemini-2.5-flash

# ── Google Cloud (required for Imagen 3, Firestore, Cloud Storage) ─────────
# Vertex AI does NOT use an API key — it authenticates via Google Cloud ADC.
#
# Two options:
#
# Option A — Service account JSON key (recommended for local dev without gcloud)
#   1. Create a service account in GCP Console with these roles:
#      - Vertex AI User              (for Imagen 3)
#      - Cloud Datastore User        (for Firestore)
#      - Storage Object Admin        (for Cloud Storage)
#   2. Download the JSON key and point this variable to it:
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json
#
# Option B — gcloud Application Default Credentials (simpler for local dev)
#   Run once: gcloud auth application-default login
#   Then leave GOOGLE_APPLICATION_CREDENTIALS blank.
#   On Cloud Run, the attached service account is used automatically.

GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# ── CORS (production only) ─────────────────────────────────────────────────
# Set this on Cloud Run to your Firebase Hosting URLs (comma-separated).
# Leave unset locally — defaults to http://localhost:5173 (Vite dev server).
# With Firebase Hosting rewrites, browsers never make cross-origin requests,
# so this only matters for direct API access (e.g. from staging/testing tools).
CORS_ORIGINS=https://your-project.web.app,https://your-project.firebaseapp.com

# ── Firestore ──────────────────────────────────────────────────────────────
FIRESTORE_COLLECTION=scenes

# ── Cloud Storage ──────────────────────────────────────────────────────────
# GCS bucket for storing generated panel images (must be publicly readable)
GCS_BUCKET_NAME=your-gcs-bucket-name
